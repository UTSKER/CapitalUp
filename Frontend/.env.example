# CapitalUp Frontend Environment Variables Template
# Copy this file to '.env' or '.env.local' and set the correct values.

# Application Environment (development, staging, production)
VITE_APP_ENV=development

# Backend API base URL
VITE_API_URL=http://localhost:3000

# Google OAuth web client ID. Use the same value as GOOGLE_CLIENT_ID in
# capitalup-backend/.env. This identifier is intended to be public in a
# browser application.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional configuration settings
VITE_ENABLE_ANALYTICS=false
VITE_MAINTENANCE_MODE=false
