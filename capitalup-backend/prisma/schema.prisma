generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model aadhaar_details {
  aadhaar_id     BigInt    @id @default(autoincrement())
  user_id        BigInt    @unique
  aadhaar_number String    @unique @db.VarChar(12)
  aadhaar_front  String?   @db.VarChar(500)
  aadhaar_back   String?   @db.VarChar(500)
  verification   String?   @default("PENDING") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  users          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_aadhaar_details_user")
  kyc            kyc?
}

model bank_accounts {
  bank_id        BigInt    @id @default(autoincrement())
  user_id        BigInt    @unique
  bank_name      String?   @db.VarChar(255)
  account_number String    @unique @db.VarChar(50)
  ifsc_code      String    @db.VarChar(20)
  account_holder String?   @db.VarChar(255)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  users          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bank_accounts_user")
  kyc            kyc?
}

model kyc {
  kyc_id            BigInt             @id @default(autoincrement())
  user_id           BigInt             @unique
  pan_id            BigInt?            @unique
  aadhaar_id        BigInt?            @unique
  signature_id      BigInt?            @unique
  bank_id           BigInt?            @unique
  kyc_status        String             @default("NOT_STARTED") @db.VarChar(50)
  submitted_at      DateTime?          @db.Timestamp(6)
  approved_at       DateTime?          @db.Timestamp(6)
  remarks           String?
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  updated_at        DateTime?          @default(now()) @db.Timestamp(6)
  aadhaar_details   aadhaar_details?   @relation(fields: [aadhaar_id], references: [aadhaar_id], onUpdate: NoAction, map: "fk_kyc_aadhaar")
  bank_accounts     bank_accounts?     @relation(fields: [bank_id], references: [bank_id], onUpdate: NoAction, map: "fk_kyc_bank")
  pan_details       pan_details?       @relation(fields: [pan_id], references: [pan_id], onUpdate: NoAction, map: "fk_kyc_pan")
  signature_details signature_details? @relation(fields: [signature_id], references: [signature_id], onUpdate: NoAction, map: "fk_kyc_signature")
  users             users              @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_kyc_user")
}

model limit_orders {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        BigInt
  symbol         String       @db.VarChar(50)
  side           String       @db.VarChar(10)
  quantity       Int
  limit_price    Decimal      @db.Decimal(12, 2)
  status         String       @default("PENDING") @db.VarChar(20)
  validity       String       @default("DAY") @db.VarChar(10)
  executed_price Decimal?     @db.Decimal(12, 2)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  executed_at    DateTime?    @db.Timestamp(6)
  updated_at     DateTime?    @default(now()) @db.Timestamp(6)
  users          users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_limit_order_user")
  stop_orders    stop_orders?
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    BigInt
  title      String    @db.VarChar(255)
  message    String
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_user")
}

model orders {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    BigInt
  symbol     String    @db.VarChar(50)
  side       String    @db.VarChar(10)
  quantity   Int
  price      Decimal   @db.Decimal(12, 2)
  status     String    @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_orders_user")
}

model pan_details {
  pan_id       BigInt    @id @default(autoincrement())
  user_id      BigInt    @unique
  pan_number   String    @unique @db.VarChar(10)
  pan_name     String?   @db.VarChar(255)
  pan_front    String?   @db.VarChar(500)
  verification String?   @default("PENDING") @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  kyc          kyc?
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pan_details_user")
}

model portfolio_holdings {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           BigInt
  symbol            String   @db.VarChar(50)
  quantity          Int
  average_buy_price Decimal  @db.Decimal(12, 2)
  created_at        DateTime @default(now()) @db.Timestamp(6)
  updated_at        DateTime @default(now()) @db.Timestamp(6)
  users             users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_portfolio_user")

  @@unique([user_id, symbol], map: "unique_portfolio_user_symbol")
}

model signature_details {
  signature_id    BigInt    @id @default(autoincrement())
  user_id         BigInt    @unique
  signature_image String?   @db.VarChar(500)
  verification    String?   @default("PENDING") @db.VarChar(50)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  kyc             kyc?
  users           users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_signature_details_user")
}

model stocks {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  symbol           String    @unique @db.VarChar(50)
  company_name     String    @db.VarChar(255)
  exchange         String    @default("NSE") @db.VarChar(20)
  instrument_type  String    @default("EQUITY") @db.VarChar(20)
  sector           String?   @db.VarChar(100)
  is_active        Boolean?  @default(true)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  last_price       Decimal?  @db.Decimal(12, 2)
  day_high         Decimal?  @db.Decimal(12, 2)
  day_low          Decimal?  @db.Decimal(12, 2)
  market_open      Decimal?  @db.Decimal(12, 2)
  previous_close   Decimal?  @db.Decimal(12, 2)
  price_updated_at DateTime? @db.Timestamp(6)
}

model stop_orders {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               BigInt
  symbol                String        @db.VarChar(50)
  side                  String        @db.VarChar(10)
  quantity              Int
  stop_price            Decimal       @db.Decimal(12, 2)
  status                String        @default("PENDING") @db.VarChar(20)
  validity              String        @default("DAY") @db.VarChar(10)
  executed_price        Decimal?      @db.Decimal(12, 2)
  linked_limit_order_id String?       @unique(map: "uq_stop_orders_active_linked_limit", where: raw("((linked_limit_order_id IS NOT NULL) AND ((status)::text = 'PENDING'::text))")) @db.Uuid
  created_at            DateTime?     @default(now()) @db.Timestamp(6)
  executed_at           DateTime?     @db.Timestamp(6)
  updated_at            DateTime?     @default(now()) @db.Timestamp(6)
  limit_orders          limit_orders? @relation(fields: [linked_limit_order_id], references: [id], onUpdate: NoAction, map: "fk_stop_order_linked_limit")
  users                 users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stop_order_user")

  @@index([status], map: "idx_stop_orders_status")
  @@index([user_id, symbol, side], map: "idx_stop_orders_user_symbol_side")
}

model user_profile {
  profile_id     BigInt    @id @default(autoincrement())
  user_id        BigInt    @unique
  full_name      String?   @db.VarChar(100)
  father_name    String?   @db.VarChar(100)
  mother_name    String?   @db.VarChar(100)
  dob            DateTime? @db.Date
  gender         String?   @db.VarChar(20)
  occupation     String?   @db.VarChar(100)
  income         String?   @db.VarChar(50)
  address        String?
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  pincode        String?   @db.VarChar(10)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  marital_status String?   @db.VarChar(30)
  users          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_profile_user")
}

model users {
  user_id            BigInt               @id @default(autoincrement())
  full_name          String               @db.VarChar(100)
  email              String               @unique @db.VarChar(255)
  mobile_number      String?              @unique @db.VarChar(15)
  password_hash      String
  role               String               @default("USER") @db.VarChar(20)
  is_email_verified  Boolean              @default(false)
  is_mobile_verified Boolean              @default(false)
  is_name_locked     Boolean              @default(false)
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @default(now()) @db.Timestamp(6)
  balance            Decimal              @default(15000.00) @db.Decimal(12, 2)
  aadhaar_details    aadhaar_details?
  bank_accounts      bank_accounts?
  kyc                kyc?
  limit_orders       limit_orders[]
  notifications      notifications[]
  orders             orders[]
  pan_details        pan_details?
  portfolio_holdings portfolio_holdings[]
  signature_details  signature_details?
  stop_orders        stop_orders[]
  user_profile       user_profile?
  watchlists         watchlists[]
  
  // New Payment Relations
  wallets            wallets?
  payment_orders     payment_orders[]
  deposits           deposits[]
  refunds            refunds[]
  withdrawals        withdrawals[]
}

model watchlists {
  watchlist_id BigInt    @id @default(autoincrement())
  user_id      BigInt
  symbol       String    @db.VarChar(30)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_watchlist_user")

  @@unique([user_id, symbol], map: "unique_user_symbol")
}

// ==========================================
// NEW PAYMENT, WALLET, LEDGER AND WEBHOOK MODELS
// ==========================================

model wallets {
  id                BigInt           @id @default(autoincrement())
  user_id           BigInt           @unique
  available_balance Decimal          @default(0.00) @db.Decimal(18, 2)
  hold_balance      Decimal          @default(0.00) @db.Decimal(18, 2)
  currency          String           @default("INR") @db.VarChar(10)
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @db.Timestamp(6)
  
  users             users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  deposits          deposits[]
  withdrawals       withdrawals[]
  ledger_entries    ledger_entries[]
}

model payment_orders {
  id                BigInt           @id @default(autoincrement())
  user_id           BigInt
  razorpay_order_id String           @unique @db.VarChar(255)
  amount            Decimal          @db.Decimal(18, 2)
  currency          String           @default("INR") @db.VarChar(10)
  status            String           @default("PENDING") @db.VarChar(50) // PENDING, PAID, FAILED, EXPIRED
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @db.Timestamp(6)

  users             users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  deposits          deposits?
}

model deposits {
  id                  BigInt           @id @default(autoincrement())
  user_id             BigInt
  wallet_id           BigInt
  payment_order_id    BigInt           @unique
  razorpay_payment_id String           @unique @db.VarChar(255)
  amount              Decimal          @db.Decimal(18, 2)
  status              String           @db.VarChar(50) // PENDING, COMPLETED, FAILED
  payment_method      String?          @db.VarChar(50)
  gateway_response    Json?
  created_at          DateTime         @default(now()) @db.Timestamp(6)

  users               users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  wallets             wallets          @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  payment_orders      payment_orders   @relation(fields: [payment_order_id], references: [id], onDelete: Cascade)
  refunds             refunds[]
}

model refunds {
  id                 BigInt           @id @default(autoincrement())
  deposit_id         BigInt
  user_id            BigInt
  razorpay_refund_id String           @unique @db.VarChar(255)
  amount             Decimal          @db.Decimal(18, 2)
  reason             String?          @db.Text
  status             String           @db.VarChar(50) // PENDING, COMPLETED, FAILED
  created_at         DateTime         @default(now()) @db.Timestamp(6)

  users              users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  deposits           deposits         @relation(fields: [deposit_id], references: [id], onDelete: Cascade)
}

model withdrawals {
  id              BigInt           @id @default(autoincrement())
  user_id         BigInt
  wallet_id       BigInt
  amount          Decimal          @db.Decimal(18, 2)
  status          String           @db.VarChar(50) // PENDING, PROCESSING, SUCCESS, FAILED, REVERSED
  bank_reference  String?          @db.VarChar(255)
  idempotency_key String           @unique @db.VarChar(255)
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @db.Timestamp(6)

  users           users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  wallets         wallets          @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
}

model ledger_transactions {
  id             BigInt           @id @default(autoincrement())
  reference_type String           @db.VarChar(50) // DEPOSIT, REFUND, WITHDRAWAL, TRADE, etc.
  reference_id   BigInt
  description    String?          @db.Text
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  
  ledger_entries ledger_entries[]
}

model ledger_entries {
  id             BigInt              @id @default(autoincrement())
  transaction_id BigInt
  wallet_id      BigInt
  account        String              @db.VarChar(100) // LIABILITY:USER_WALLET, ASSET:BANK, etc.
  entry_type     String              @db.VarChar(10) // DEBIT, CREDIT
  amount         Decimal             @db.Decimal(18, 2)
  balance_before Decimal             @db.Decimal(18, 2)
  balance_after  Decimal             @db.Decimal(18, 2)
  created_at     DateTime            @default(now()) @db.Timestamp(6)

  ledger_tx      ledger_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  wallets        wallets             @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
}

model webhook_events {
  id           BigInt    @id @default(autoincrement())
  gateway      String    @db.VarChar(50)
  event_id     String    @unique @db.VarChar(255)
  event_type   String    @db.VarChar(255)
  payload      Json
  processed    Boolean   @default(false)
  received_at  DateTime  @default(now()) @db.Timestamp(6)
  processed_at DateTime? @db.Timestamp(6)
}
